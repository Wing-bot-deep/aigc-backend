# =============================================
# 蓝色光标 AIGC 营销素材生成服务 - 环境变量配置
# 复制本文件为 .env 并填写你的 API Key
# =============================================

# --- LLM 配置（OpenAI 兼容格式）---
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://codex.ai02.cn/v1
LLM_MODEL=gpt-4o

# --- 图片生成后端 ---
# mock    : 本地测试，不调用真实接口（默认）
# dalle3  : 使用 OpenAI DALL-E 3（需要 OpenAI Key）
# comfyui : 本地 Flux/SDXL 服务（需要在服务器上跑 ComfyUI）
IMAGE_BACKEND=mock

# ComfyUI 配置（IMAGE_BACKEND=comfyui 时填写）
COMFYUI_URL=http://localhost:8188

# --- 质量控制 ---
QUALITY_THRESHOLD=7.0

# --- 服务配置 ---
HOST=0.0.0.0
PORT=8000
